# 运行模式；服务端必填。生产环境使用 production。
NODE_ENV=development
# HTTP 监听端口；服务端可选，默认 3000。
PORT=3000
# MySQL 连接；服务端必填，禁止使用 EXPO_PUBLIC_ 前缀或提交真实密码。
DATABASE_URL=mysql://shenghuobang:replace_local_password@127.0.0.1:3306/shenghuobang
# 会话 JWT 签名；服务端必填，生产至少 32 个随机字符。
JWT_SECRET=replace-with-a-strong-random-server-secret
# 文件访问 HMAC 签名；服务端必填，必须与 JWT_SECRET 不同。
FILE_SIGNING_SECRET=replace-with-another-strong-random-server-secret
# 允许的 Web Origin，逗号分隔；生产服务端必填且不允许 *。
CORS_ORIGINS=http://localhost:8081
# 是否允许不能发送 Origin 的原生 WebSocket 客户端；服务端可选，生产须明确评估后开启。
WS_ALLOW_NATIVE_WITHOUT_ORIGIN=true
# WebSocket 资源限制；服务端可选。
WS_MAX_CONNECTIONS_PER_USER=3
WS_MAX_SUBSCRIPTIONS=20
WS_MAX_MESSAGE_BYTES=16384

# Expo 客户端可公开的 API 地址；允许 EXPO_PUBLIC_，不得包含密钥。
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# 普通 API 请求超时毫秒数；客户端可公开，默认 15000。
EXPO_PUBLIC_API_TIMEOUT_MS=15000
# Expo 客户端可公开的 WebSocket 地址；可选，缺省由 API 地址推导。
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:3000
# EAS Project ID；公开项目标识，不是 Access Token。development build 获取 Expo Push Token 时需要。
EXPO_PUBLIC_EAS_PROJECT_ID=
# 应用包标识；构建时可公开。
APP_BUNDLE_ID=com.shenghuobang.app
# 服务端公开基址；可选，不得包含签名参数。
PUBLIC_BASE_URL=http://localhost:3000

# OpenAI 兼容 AI 服务地址；服务端可选。
AI_API_URL=https://api.deepseek.com
# AI 密钥；仅服务端可选，禁止使用 EXPO_PUBLIC_。
AI_API_KEY=
# AI 模型名；服务端可选。
AI_MODEL=deepseek-chat

# 支付 Provider；服务端必填，本阶段仅 sandbox，不能处理真实资金。
PAYMENT_PROVIDER=sandbox
# 推送 Provider；服务端可选 log 或 expo。没有真机凭据时保持 log。
PUSH_PROVIDER=log
# Expo Push 安全 Access Token；仅服务端可选，启用 EAS Push Security 时填写，禁止使用 EXPO_PUBLIC_ 前缀。
EXPO_PUSH_ACCESS_TOKEN=

# 存储 Provider；服务端必填，可选 local 或 s3。
STORAGE_PROVIDER=local
# Local 私有上传目录；local 时服务端必填，不得位于 assets/public/web-dist。
LOCAL_UPLOAD_DIR=./uploads
# 单文件最大字节数；服务端可选，默认 8 MiB。
MAX_UPLOAD_BYTES=8388608
# 同一业务对象最大文件数；服务端可选。
MAX_FILES_PER_ENTITY=20
# S3 兼容端点；s3 时服务端必填，例如 MinIO/R2/S3 endpoint。
S3_ENDPOINT=
# S3 区域；s3 时服务端必填。
S3_REGION=auto
# S3 bucket；s3 时服务端必填。
S3_BUCKET=
# S3 access key；s3 时仅服务端必填，禁止使用 EXPO_PUBLIC_。
S3_ACCESS_KEY_ID=
# S3 secret key；s3 时仅服务端必填，禁止使用 EXPO_PUBLIC_。
S3_SECRET_ACCESS_KEY=
# S3 路径风格；服务端可选，MinIO 等兼容服务常用 true。
S3_FORCE_PATH_STYLE=false
