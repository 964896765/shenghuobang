{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "development",
        "EXPO_PUBLIC_RELEASE_CHANNEL": "development"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "lan-demo": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "lan-demo",
        "EXPO_PUBLIC_RELEASE_CHANNEL": "alpha"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "staging",
        "EXPO_PUBLIC_RELEASE_CHANNEL": "staging"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_BUILD_PROFILE": "production",
        "EXPO_PUBLIC_RELEASE_CHANNEL": "production"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
