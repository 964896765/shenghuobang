{
  "name": "shenghuobang",
  "version": "3.2.4",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --web --port 8081",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.mjs",
    "start": "cross-env NODE_ENV=production node dist/index.mjs",
    "check": "tsc --noEmit",
    "lint": "expo lint --max-warnings 0",
    "validate:product-specs": "node scripts/validate-product-specs.mjs",
    "check:markdown-links": "node scripts/check-markdown-links.mjs",
    "format": "prettier --write .",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true --teardownTimeout=1000",
    "test:integration:mysql": "pnpm test:integration:v311 && pnpm test:integration:v312",
    "test:integration:v311": "tsx scripts/test-v31-1-integration.ts",
    "test:integration:v312": "tsx scripts/test-v31-2-integration.ts",
    "test:integration:v32": "tsx scripts/test-v32-integration.ts && tsx scripts/test-v32-upgrade.ts && tsx scripts/test-v32-runtime.ts",
    "test:location:mysql": "tsx scripts/test-location-integration.ts",
    "test:migrations:empty": "tsx scripts/test-empty-migrations.ts",
    "db:repair:v32": "tsx scripts/repair-v32-data.ts",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "test:seed:idempotent": "tsx scripts/test-seed-idempotency.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "verify": "pnpm check && pnpm lint && pnpm test && pnpm build",
    "build:web": "expo export --platform web --output-dir web-dist --max-workers 1 --no-minify",
    "source:archive": "node scripts/create-source-archive.mjs",
    "test:money:v330": "tsx scripts/test-v33-money-unit.ts",
    "audit:money:v330": "tsx scripts/audit-v33-money-migration.ts",
    "verify:v330:phase1": "pnpm validate:product-specs && pnpm check:markdown-links && pnpm check:money:v330 && pnpm check && pnpm lint && pnpm test && pnpm test:money:v330 && pnpm build",
    "check:money:v330": "node scripts/check-v33-money-registry.mjs",
    "check:v33-a2-schema": "node scripts/check-v33-a2-schema.mjs",
    "test:v33-a2-infrastructure": "node scripts/test-v33-a2-infrastructure.mjs",
    "test:v33-a2-seeds": "node scripts/test-v33-a2-seeds.mjs",
    "test:v33-a2-empty-db": "node scripts/test-v33-a2-empty-db.mjs",
    "test:v33-rc11:mysql-remediation": "node scripts/test-v33-rc11-mysql-remediation.mjs",
    "seed:v33-a2-directories": "node scripts/seed-v33-a2-directories.mjs",
    "check:v33-a2-business-schema": "node scripts/check-v33-a2-business-schema.mjs",
    "migrate:v33-a2-backfill": "tsx scripts/run-v33-a2-backfill.ts",
    "test:v33-a2-backfill": "tsx scripts/test-v33-a2-backfill.ts",
    "test:v33-a3-authorization": "tsx scripts/test-v33-a3-authorization.ts",
    "test:v33-a3-routes": "tsx scripts/test-v33-a3-route-integration.ts",
    "test:v33-a3-integration-fixes": "tsx scripts/test-v33-a3-authorization-integration-fixes.ts",
    "test:v33-a4-identity-organization": "tsx scripts/test-v33-a4-identity-organization.ts",
    "test:v33-a5-workspace-mobile": "tsx scripts/test-v33-a5-workspace-mobile.ts",
    "test:v33-b1-idea-service": "tsx scripts/test-v33-b1-idea-service.ts",
    "test:v33-b1-idea-routes": "tsx scripts/test-v33-b1-idea-routes.ts",
    "test:v33-b1-idea-app": "tsx scripts/test-v33-b1-idea-app.ts",
    "test:v33-b1-1-collaborator-search": "tsx scripts/test-v33-b1-1-collaborator-search.ts",
    "test:v33-b2-1-design-prototype-backend": "tsx scripts/test-v33-b2-1-design-prototype-backend.ts",
    "test:v33-b2-2-design-prototype-app": "tsx scripts/test-v33-b2-2-design-prototype-app.ts",
    "test:v33-b3-1-acceptance-intent-backend": "tsx scripts/test-v33-b3-1-acceptance-intent-backend.ts",
    "test:v33-b3-2-acceptance-intent-app": "tsx scripts/test-v33-b3-2-acceptance-intent-app.ts"
  },
